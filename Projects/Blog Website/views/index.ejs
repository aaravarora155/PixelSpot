<!DOCTYPE html>
<html>
    <head>
        <title>Blog Application</title>
        <link href="styles.css" rel="stylesheet">
    </head>
    <body>
        <div id="header">
            <h1>Home</h1>
            <form action="/create" method="POST">
                <input id="create" type="submit" value="Create Post">
            </form>
        </div>

        <%if (locals.message&&locals.type){%>
            <div class="tile">
                <%if (type===true){%>
                    <%-message%>
                <%}%>
            </div>
        <%}%>
        <div id="form">
            <form class="buttonPan" method="POST" action="/options">
                <div id="title">
                    <label>Title</label>
                    <input type="text" name="title" placeholder="Enter Title" required>
                </div>
                <div id="content">
                    <textarea name="bodyPost" rows="6" cols="80" placeholder="Post Body"></textarea>
                    <br>
                </div>
                <div id="buttons">
                    <input id="edit" type="submit" value="Edit" formaction="/edit">
                    <input id="view" type="submit" value="View" formaction="/view">
                    <input id="delete" type="submit" value="Delete" formaction="/delete">
                </div>

            </form>
        </div>
    </body>
</html>